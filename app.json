{
  "expo": {
    "name": "UnFocus",
    "slug": "unfocus",
    "owner": "freyrnor-pixel",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "unfocus",
    "runtimeVersion": "1.1.0",
    "updates": {
      "url": "https://u.expo.dev/9c7c7e82-8c6e-4be7-aae1-e588b4ebc495",
      "channel": "preview"
    },
    "intentFilters": [
      {
        "action": "VIEW",
        "data": [
          {"scheme": "unfocus", "host": "*"},
          {"scheme": "https", "host": "unfocus.app"}
        ],
        "category": ["BROWSABLE", "DEFAULT"]
      }
    ],
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F4A261"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow UnFocus to use your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow UnFocus to access your photos to scan receipts."
        }
      ],
      "expo-audio",
      "expo-task-manager",
      "expo-background-task",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow UnFocus to access your photo library.",
          "saveToPhotosPermission": "Allow UnFocus to save images to your photo library."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": []
        }
      ],
      "@bacons/apple-targets"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.freyrnorpixel.unfocus",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.freyrnorpixel.unfocus"]
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "UnFocus uses the microphone so you can record voice notes.",
        "NSPhotoLibraryUsageDescription": "UnFocus can add a receipt photo from your library so you can scan it.",
        "NSPhotoLibraryAddUsageDescription": "UnFocus can save receipt photos to your photo library.",
        "UIBackgroundModes": ["fetch", "processing"]
      }
    },
    "android": {
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.freyrnorpixel.unfocus",
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9c7c7e82-8c6e-4be7-aae1-e588b4ebc495"
      }
    }
  }
}
